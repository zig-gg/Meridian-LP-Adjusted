# ── Wallet ────────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Solana RPC ─────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Option A: OpenRouter (default — recommended)
# Priority: OPENROUTER_API_KEY > OPENAI_API_KEY > LLM_API_KEY
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_SITE_URL=https://github.com/zig-gg/Meridian-LP
OPENROUTER_APP_NAME=Meridian-LP

# Option B: OpenAI-compatible endpoint (also works with OpenRouter)
# Uncomment and fill in if you prefer OPENAI_ env names
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=deepseek/deepseek-v4-pro

# Option C: LM Studio or other local server
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=your-model-name-from-lmstudio

# ── API Keys ───────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here
LPAGENT_API_KEY=your_lpagent_api_key_here

# ── Telegram Notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# ── Dangerous admin actions (disabled by default) ─────────────────────────────
ALLOW_SELF_UPDATE=false

# ── Phase 1: Execution scaffold ────────────────────────────────────────────────
# Dedicated bot wallet for autonomous execution (separate from main wallet).
# Generate with: node scripts/gen-bot-wallet.js --write-env
# Leave blank until you have generated and funded a dedicated bot wallet.
BOT_WALLET_PRIVATE_KEY=

# Must be explicitly set to true to allow any live on-chain broadcast.
# Default false — scanner/simulate/paper modes work without this.
ALLOW_LIVE_EXECUTION=false

# Execution mode: scanner | simulate | paper | live
# scanner  = scan/rank/report only (default, safest)
# simulate = build intent + dry-run, no broadcast
# paper    = record hypothetical action only
# live     = broadcast only if ALL hard gates pass
EXECUTION_MODE=scanner

# ── Misc ───────────────────────────────────────────────────────────────────────
DRY_RUN=false
LOG_LEVEL=info
