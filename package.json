{
  "name": "dlmm-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Autonomous DLMM LP agent for Meteora on Solana",
  "main": "index.js",
  "bin": {
    "meridian": "cli.js"
  },
  "scripts": {
    "setup": "node setup.js",
    "env:encrypt": "node scripts/envrypt.js encrypt",
    "start": "node index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart meridian --update-env",
    "pm2:logs": "pm2 logs meridian --lines 100",
    "dev": "cross-env DRY_RUN=true node index.js",
    "test": "npm run test:syntax",
    "test:syntax": "node scripts/check-syntax.js",
    "test:screen": "node test/test-screening.js",
    "test:agent": "cross-env DRY_RUN=true node test/test-agent.js",
    "test:phase1": "node test/test-phase1.js",
    "postinstall": "node scripts/patch-anchor.js"
  },
  "knip": {
    "ignore": [
      "discord-listener/**"
    ]
  },
  "dependencies": {
    "@meteora-ag/dlmm": "1.9.4",
    "@solana/web3.js": "^1.95.0",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "dotenv": "^17.3.1",
    "jsonrepair": "^3.13.3",
    "node-cron": "^3.0.3",
    "openai": "^4.73.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
